{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.adelaidasofia/rescuetime-mcp",
  "title": "MCP server for RescueTime productivity data",
  "description": "MCP server for RescueTime productivity data",
  "version": "0.1.0",
  "repository": {
    "url": "https://github.com/adelaidasofia/rescuetime-mcp",
    "source": "github"
  },
  "packages": [
    {
      "registryType": "mcpb",
      "identifier": "https://github.com/adelaidasofia/rescuetime-mcp/releases/latest/download/rescuetime-mcp.mcpb",
      "version": "0.1.0",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "RESCUETIME_API_KEY",
          "description": "From rescuetime.com \u2192 Account \u2192 API",
          "isRequired": true,
          "isSecret": true
        }
      ]
    }
  ]
}
